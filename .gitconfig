[alias]
    c = commit
    co = checkout
    cob = checkout -b
    p = push
    s = status -s

    dt = difftool
    mt = mergetool

    wtf = blame

    # Updating local branch
    u = merge --ff-only
    l = fetch -tap

    # Commit graph
    tree = "log --color --graph --pretty=format:'%C(bold red)%d%C(reset)%n %C(bold 8)%h%C(reset) %C(white)%s%C(reset)%n            %C(bold white)%aN (%aE)%C(reset)%n            %C(italic yellow)%ar%C(reset)' --decorate=short"
    t    = "log --color --graph --pretty=format:'%C(8)%C(bold)%h%C(reset)%C(bold red)%d%C(reset) %C(white)%s%C(reset)' --all"
    ts   = "log --color --graph --pretty=format:'%C(8)%C(bold)%h%C(reset)%C(bold red)%d%C(reset) %C(white)%s%C(reset)'"
    tv   = "log --color --graph --pretty=format:'%C(8)%C(bold)%h%C(reset) %G?%C(bold red)%d%C(reset) %C(white)%s%C(reset)' --all"

[init]
    defaultBranch = main
[color]
    ui = auto
[credential]
    helper = osxkeychain
[core]
    editor = nvim
    excludesfile = ~/.gitignore-global
    attributesfile = ~/.gitattributes
    pager = ov -F
    autocrlf = input
    ignorecase = false
[color "diff"]
    meta = yellow bold
    commit = green bold
    frag = magenta bold
    old = red bold
    new = green bold
    whitespace = red reverse
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[mergetool "nvim"]
    cmd = nvim -f -c \"Gdiffsplit!\" \"$MERGED\"
    prompt = false
    keepbackup = false
[merge]
    log = true
    defaultToUpstream = true
    tool = nvim
    conflictstyle = diff3
    prompt = false

[rebase]
    autostash = true

[help]
    autocorrect = prompt
[push]
    default = current

[delta "woolly-mammoth"]
    # author: https://github.com/Kr1ss-XD
    commit-decoration-style = 232 130 box
    commit-style = 232 bold italic 130
    dark = true
    file-decoration-style = 3 overline
    file-added-label = [+]
    file-copied-label = [==]
    file-modified-label = [*]
    file-removed-label = [-]
    file-renamed-label = [->]
    file-style = 5 bold
    hunk-header-decoration-style = none
    hunk-header-style = syntax bold italic 237
    line-numbers = true
    line-numbers-left-format = " {nm:>1} ┊"
    line-numbers-left-style = red
    line-numbers-minus-style = red italic black
    line-numbers-plus-style = green italic black
    line-numbers-right-format = " {np:>1} │"
    line-numbers-right-style = green
    line-numbers-zero-style = 8 italic
    minus-emph-style = syntax bold 1
    minus-style = syntax "#400000"
    plus-emph-style = syntax bold 2
    plus-style = syntax "#004000"
    syntax-theme = Dracula
    whitespace-error-style = "#280050" reverse
    zero-style = syntax
    blame-format = "{author:<18} ({commit:>7}) ┊{timestamp:^16}┊ "
    blame-palette = "#101010 #200020 #002800 #000028 #202000 #280000 #002020 #002800 #202020"

[delta]
    navigate = true
    line-numbers = true
    wrap-max-lines = 0
    max-line-length = 0
    features = woolly-mammoth

[pager]
    diff = delta --pager='ov -F'
    show = delta --pager='ov -F'
    log = ov -F
    stash = delta --pager='ov -F'

[interactive]
    diffFilter = delta --color-only --wrap-max-lines 0

[diff]
    colorMoved = default

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process

[include]
    path = ~/.gitconfig.local
