{
  "lspServers": {
    "python": {
      "command": "${HOME}/.local/share/nvim/mason/bin/basedpyright-langserver",
      "args": ["--stdio"],
      "fileExtensions": {
        ".py": "python"
      }
    },
    "typescript": {
      "command": "${HOME}/.local/share/nvim/mason/bin/typescript-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    }
  }
}
