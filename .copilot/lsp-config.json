{
  "lspServers": {
    "lua": {
      "command": "${HOME}/.local/share/nvim/mason/bin/lua-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".lua": "lua"
      }
    },
    "python": {
      "command": "${HOME}/.local/share/nvim/mason/bin/basedpyright-langserver",
      "args": ["--stdio"],
      "fileExtensions": {
        ".py": "python"
      }
    },
    "typescript": {
      "command": "${HOME}/.local/share/nvim/mason/bin/typescript-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    },
    "cpp": {
      "command": "ccls",
      "args": ["--stdio"],
      "fileExtensions": {
        ".cpp": "cpp",
        ".h": "cpp"
      }
    }
  }
}
